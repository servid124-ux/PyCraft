{
  "types": {
    "packet_identification": ["container", [
      {"name": "protocol_version", "type": "u8"},
      {"name": "username",         "type": "string64"},
      {"name": "verification_key", "type": "string64"},
      {"name": "user_type",        "type": "u8"}
    ]],
    "packet_ping":             ["container", []],
    "packet_level_initialize": ["container", []],
    "packet_level_data_chunk": ["container", [
      {"name": "chunk_length",    "type": "u16"},
      {"name": "chunk_data",      "type": "array1024"},
      {"name": "percent_complete","type": "u8"}
    ]],
    "packet_level_finalize": ["container", [
      {"name": "size_x", "type": "u16"},
      {"name": "size_y", "type": "u16"},
      {"name": "size_z", "type": "u16"}
    ]],
    "packet_set_block_client": ["container", [
      {"name": "x",          "type": "i16"},
      {"name": "y",          "type": "i16"},
      {"name": "z",          "type": "i16"},
      {"name": "mode",       "type": "u8"},
      {"name": "block_type", "type": "u8"}
    ]],
    "packet_set_block_server": ["container", [
      {"name": "x",          "type": "i16"},
      {"name": "y",          "type": "i16"},
      {"name": "z",          "type": "i16"},
      {"name": "block_type", "type": "u8"}
    ]],
    "packet_spawn_player": ["container", [
      {"name": "player_id", "type": "i8"},
      {"name": "name",      "type": "string64"},
      {"name": "x",         "type": "fpos"},
      {"name": "y",         "type": "fpos"},
      {"name": "z",         "type": "fpos"},
      {"name": "yaw",       "type": "u8"},
      {"name": "pitch",     "type": "u8"}
    ]],
    "packet_player_teleport": ["container", [
      {"name": "player_id", "type": "i8"},
      {"name": "x",         "type": "fpos"},
      {"name": "y",         "type": "fpos"},
      {"name": "z",         "type": "fpos"},
      {"name": "yaw",       "type": "u8"},
      {"name": "pitch",     "type": "u8"}
    ]],
    "packet_position_orientation_update": ["container", [
      {"name": "player_id", "type": "i8"},
      {"name": "dx",        "type": "i8"},
      {"name": "dy",        "type": "i8"},
      {"name": "dz",        "type": "i8"},
      {"name": "yaw",       "type": "u8"},
      {"name": "pitch",     "type": "u8"}
    ]],
    "packet_position_update": ["container", [
      {"name": "player_id", "type": "i8"},
      {"name": "dx",        "type": "i8"},
      {"name": "dy",        "type": "i8"},
      {"name": "dz",        "type": "i8"}
    ]],
    "packet_orientation_update": ["container", [
      {"name": "player_id", "type": "i8"},
      {"name": "yaw",       "type": "u8"},
      {"name": "pitch",     "type": "u8"}
    ]],
    "packet_despawn_player": ["container", [
      {"name": "player_id", "type": "i8"}
    ]],
    "packet_message": ["container", [
      {"name": "player_id", "type": "i8"},
      {"name": "message",   "type": "string64"}
    ]],
    "packet_disconnect_player": ["container", [
      {"name": "reason", "type": "string64"}
    ]],
    "packet_update_user_type": ["container", [
      {"name": "user_type", "type": "u8"}
    ]],
    "packet_ext_info": ["container", [
      {"name": "app_name",        "type": "string64"},
      {"name": "extension_count", "type": "i16"}
    ]],
    "packet_ext_entry": ["container", [
      {"name": "ext_name", "type": "string64"},
      {"name": "version",  "type": "i32"}
    ]],
    "packet_custom_block_support_level": ["container", [
      {"name": "level", "type": "u8"}
    ]]
  },

  "classic": {
    "toServer": {
      "types": {
        "packet": ["container", [
          {"name": "name", "type": ["mapper", {"type": "u8", "mappings": {
            "0x00": "identification",
            "0x05": "set_block_client",
            "0x08": "player_teleport",
            "0x0D": "message",
            "0x10": "ext_info",
            "0x11": "ext_entry",
            "0x13": "custom_block_support_level"
          }}]},
          {"name": "params", "type": ["switch", {
            "compareTo": "name",
            "fields": {
              "identification":              "packet_identification",
              "set_block_client":            "packet_set_block_client",
              "player_teleport":             "packet_player_teleport",
              "message":                     "packet_message",
              "ext_info":                    "packet_ext_info",
              "ext_entry":                   "packet_ext_entry",
              "custom_block_support_level":  "packet_custom_block_support_level"
            },
            "default": "packet_ping"
          }]}
        ]]
      }
    },
    "toClient": {
      "types": {
        "packet": ["container", [
          {"name": "name", "type": ["mapper", {"type": "u8", "mappings": {
            "0x00": "identification",
            "0x01": "ping",
            "0x02": "level_initialize",
            "0x03": "level_data_chunk",
            "0x04": "level_finalize",
            "0x06": "set_block_server",
            "0x07": "spawn_player",
            "0x08": "player_teleport",
            "0x09": "position_orientation_update",
            "0x0A": "position_update",
            "0x0B": "orientation_update",
            "0x0C": "despawn_player",
            "0x0D": "message",
            "0x0E": "disconnect_player",
            "0x0F": "update_user_type",
            "0x10": "ext_info",
            "0x11": "ext_entry",
            "0x13": "custom_block_support_level"
          }}]},
          {"name": "params", "type": ["switch", {
            "compareTo": "name",
            "fields": {
              "identification":              "packet_identification",
              "ping":                        "packet_ping",
              "level_initialize":            "packet_level_initialize",
              "level_data_chunk":            "packet_level_data_chunk",
              "level_finalize":              "packet_level_finalize",
              "set_block_server":            "packet_set_block_server",
              "spawn_player":                "packet_spawn_player",
              "player_teleport":             "packet_player_teleport",
              "position_orientation_update": "packet_position_orientation_update",
              "position_update":             "packet_position_update",
              "orientation_update":          "packet_orientation_update",
              "despawn_player":              "packet_despawn_player",
              "message":                     "packet_message",
              "disconnect_player":           "packet_disconnect_player",
              "update_user_type":            "packet_update_user_type",
              "ext_info":                    "packet_ext_info",
              "ext_entry":                   "packet_ext_entry",
              "custom_block_support_level":  "packet_custom_block_support_level"
            }
          }]}
        ]]
      }
    }
  }
}
